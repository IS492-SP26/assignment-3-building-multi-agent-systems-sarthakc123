# API Keys - Copy this file to .env and fill in your actual keys
# DO NOT commit .env file to git

# ----- Primary: Groq (recommended) -----
# Get a free API key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ----- Alternative: OpenAI-compatible / self-hosted vLLM -----
# Used only when config.yaml sets models.default.provider = "openai" or "vllm"
# Example for the assignment-provided vLLM endpoint:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://vllm.salt-lab.org/v1
#   OPENAI_MODEL=Qwen/Qwen3-8B
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ----- Web Search (choose at least one) -----
TAVILY_API_KEY=your_tavily_api_key_here
BRAVE_API_KEY=

# ----- Semantic Scholar (optional, has free tier) -----
SEMANTIC_SCHOLAR_API_KEY=

# ----- Model defaults (overridable per config.yaml) -----
DEFAULT_MODEL=llama-3.3-70b-versatile
JUDGE_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7

# ----- Safety -----
ENABLE_GUARDRAILS=true
LOG_SAFETY_EVENTS=true

# ----- Logging -----
LOG_LEVEL=INFO
LOG_DIR=logs
